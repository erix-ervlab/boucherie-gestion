# Copier en `.env` et adapter. NE PAS committer le .env réel.
POSTGRES_USER=boucherie
POSTGRES_PASSWORD=change-moi-en-prod
POSTGRES_DB=boucherie

# Origines autorisées pour le front (dev Vite = 5173).
CORS_ORIGINS=http://localhost:5173

# --- Grafana (exploration en lecture seule) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-moi-en-prod
# Mot de passe du rôle Postgres lecture seule `grafana_ro`.
GRAFANA_DB_PASSWORD=change-moi-aussi
